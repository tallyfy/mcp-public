# Tallyfy MCP server — example environment.
# Copy to `.env` and fill in. These are NAMES ONLY; never commit real values.

# --- Tallyfy API ---
TALLYFY_API_BASE_URL=https://api.tallyfy.com
TALLYFY_ENVIRONMENT=production
TALLYFY_ISSUER=https://account.tallyfy.com

# --- OAuth / JWT (the server validates Tallyfy-issued bearer tokens) ---
MCP_RESOURCE_URL=https://mcp.tallyfy.com/
MCP_JWT_AUDIENCE=
ENFORCE_JWT_AUDIENCE=true
TALLYFY_PUBLIC_KEY=
MCP_SESSION_TIMEOUT=3600

# --- runtime ---
PORT=9000
FASTMCP_LOG_LEVEL=INFO
LOG_VERBOSITY=normal
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60

# --- observability (optional) ---
SENTRY_ENABLED=false
SENTRY_DSN=
SENTRY_ENVIRONMENT=
OTEL_SERVICE_NAME=tallyfy-mcp-server

# --- internal/admin endpoints (optional; leave blank for public deployments) ---
METRICS_USERNAME=
METRICS_PASSWORD=
METRICS_ALLOWED_IPS=
